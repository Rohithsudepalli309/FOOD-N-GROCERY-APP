# F&G Production Environment Variables
# Copy to each service's .env and fill in real values

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Database (PostgreSQL + PostGIS) ─────────────────────────────────────────
DATABASE_URL=postgresql://fg_user:fg_pass@localhost:5432/fg_db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
USE_MOCK_REDIS=true   # Set false when Redis is running

# ── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
USE_MOCK_KAFKA=true   # Set false when Kafka is running

# ── Google Maps ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIzaSy_replace_with_your_key
# Get at: console.cloud.google.com → Maps JavaScript API + Geocoding API

# ── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_replace_with_your_key
RAZORPAY_KEY_SECRET=replace_with_your_secret
# Get at: dashboard.razorpay.com → Settings → API Keys

# ── Firebase FCM ────────────────────────────────────────────────────────────
FCM_SERVER_KEY=AAAA_replace_with_firebase_server_key
EXPO_PROJECT_ID=replace_with_expo_project_id
# Get at: console.firebase.google.com → Project Settings → Cloud Messaging

# ── Twilio (SMS OTP) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_FROM_NUMBER=+1234567890

# ── AWS S3 (images) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=fg-assets-prod

# ── Mobile App ──────────────────────────────────────────────────────────────
# Update SERVER_IP to your PC's LAN IP for real device testing
# Run: ipconfig | findstr IPv4
SERVER_IP=10.0.2.2   # Android emulator → localhost
SERVER_PORT=3000      # Through API Gateway (or 3007 for direct Socket.IO)
