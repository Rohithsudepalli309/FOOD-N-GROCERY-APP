{
  "name": "@fg/tests",
  "version": "1.0.0",
  "description": "F&G — Backend Integration & Unit Test Suite",
  "private": true,
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ],
    "testTimeout": 15000,
    "clearMocks": true,
    "verbose": true
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "jest": "29.7.0",
    "supertest": "7.0.0"
  }
}
